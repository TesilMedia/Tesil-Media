// Tesil Media — Prisma schema
// Local dev uses SQLite. Swap the `provider` and `DATABASE_URL` to move to Postgres/MySQL later.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ---- Auth ----

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  name           String?
  hashedPassword String?
  image          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Comma-separated list of content ratings this user does NOT want to see
  // (e.g. "X" or "R,X"). X is hidden by default for all users.
  hiddenRatings  String    @default("X")

  channel        Channel?
  sessions       Session[]
  accounts       Account[]
  comments       Comment[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---- Content ----

model Channel {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?
  avatarUrl   String?
  bannerUrl   String?
  followers   Int      @default(0)
  createdAt   DateTime @default(now())

  ownerId String? @unique
  owner   User?   @relation(fields: [ownerId], references: [id], onDelete: SetNull)

  videos  Video[]
  stream  LiveStream?
}

model Video {
  id          String   @id @default(cuid())
  title       String
  description String?
  // Source URL — can be a YouTube/Vimeo/Twitch link OR a direct MP4/HLS URL.
  // The Tesil Video Player handles all of these natively.
  sourceUrl   String
  // JSON array of { label, url, height } for transcoded rungs. SQLite: stored as String.
  qualityVariantsJson String?
  // True while lower-quality renditions are still being encoded after publish (see upload flow).
  transcodePending    Boolean  @default(false)
  thumbnail   String?
  durationSec Int?
  views       Int      @default(0)
  // Canonical category slug. See `src/lib/categories.ts` for the full list
  // ("gaming", "music", "tech", ...). Legacy rows may still hold free-form
  // values; those are coerced via `normaliseCategory` on read.
  category    String?
  // Maturity rating: "PG" | "PG13" | "R" | "X". Stored as String for SQLite.
  rating      String   @default("PG")
  createdAt   DateTime @default(now())

  channelId String
  channel   Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  comments  Comment[]

  @@index([channelId])
  @@index([createdAt])
  @@index([rating])
  @@index([category])
}

model Comment {
  id        String    @id @default(cuid())
  body      String
  createdAt DateTime  @default(now())
  // Set the first time a comment is edited (and on every edit thereafter).
  // Null means never edited — used by the UI to show "(edited)".
  editedAt  DateTime?

  videoId String
  video   Video  @relation(fields: [videoId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Self-referential parent for threaded replies. Threads are intentionally
  // flat: a reply's parentId always points at a root comment (the API
  // collapses reply-to-reply into reply-to-root). Cascade so deleting a root
  // tears down its replies.
  parentId String?
  parent   Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies  Comment[] @relation("CommentReplies")

  @@index([videoId, createdAt])
  @@index([parentId])
}

model LiveStream {
  id          String   @id @default(cuid())
  title       String
  // Canonical category slug (see `src/lib/categories.ts`).
  category    String?
  thumbnail   String?
  // Stream URL — HLS (.m3u8), a Twitch/YouTube live URL, or a looping MP4 for dev.
  streamUrl   String
  // OBS/RTMP ingest key. Null preserves legacy/manual URL streams.
  streamKey   String?  @unique
  isLive      Boolean  @default(false)
  viewers     Int      @default(0)
  // Maturity rating: "PG" | "PG13" | "R" | "X". Stored as String for SQLite.
  rating      String   @default("PG")
  startedAt   DateTime?
  lastIngestAt DateTime?
  updatedAt   DateTime @updatedAt

  channelId String  @unique
  channel   Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@index([category])
}

# Copy this file to `.env` and adjust as needed.

# SQLite dev database (local file).
DATABASE_URL="file:./dev.db"

# NextAuth / Auth.js. Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET="change-me-to-a-long-random-string"
# Optional: canonical public URL. If set, every auth redirect uses this origin only.
# Leave unset for local dev when you sometimes open the app via LAN IP (e.g. http://192.168.x.x:3000
# on your phone); otherwise sign-in/out will keep sending you to whatever host is below.
# AUTH_URL="http://localhost:3000"
# (Legacy name; Auth.js reads AUTH_URL first, then this.)
# NEXTAUTH_URL="http://localhost:3000"

# Shared secret between Node Media Server and /api/stream/hook
STREAM_HOOK_SECRET="change-me-to-a-long-random-string"

# Where `scripts/media-server.mjs` POSTs ingest hooks. Must match the URL Next prints
# (same host/port). Example if `next dev` uses 3004: http://localhost:3004
# NEXT_APP_URL="http://localhost:3000"

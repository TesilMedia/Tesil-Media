{
  "name": "tesil-media",
  "version": "0.1.0",
  "private": true,
  "description": "Tesil Media — streaming site (VOD + live) powered by the Tesil Video Player",
  "scripts": {
    "dev": "next dev",
    "dev:media": "node --env-file=.env scripts/media-server.mjs",
    "dev:all": "concurrently -n next,media -c cyan,magenta \"npm:dev\" \"npm:dev:media\"",
    "setup:mediamtx": "node scripts/setup-mediamtx.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:migrate-categories": "tsx prisma/migrate-categories.ts",
    "db:studio": "prisma studio",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.7.4",
    "@fastify/busboy": "^3.2.0",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "concurrently": "^9.2.1",
    "jose": "^6.2.2",
    "next": "^15.1.0",
    "next-auth": "5.0.0-beta.25",
    "node-media-server": "^4.2.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.9.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.14",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
